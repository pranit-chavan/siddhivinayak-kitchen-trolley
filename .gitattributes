# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Force LF for web files
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.md   text eol=lf
*.env* text eol=lf

# Binaries — don't touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  binary
*.pdf  binary
*.docx binary
