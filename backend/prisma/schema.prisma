// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  OWNER
  ADMIN
  STAFF
}

enum LeadSource {
  WEBSITE
  WHATSAPP
  CALL
  REFERRAL
  WALK_IN
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  SITE_VISIT_SCHEDULED
  QUALIFIED
  CONVERTED
  LOST
}

enum ProjectStatus {
  INQUIRY
  SITE_VISIT
  MEASUREMENT
  DESIGN
  QUOTATION_SENT
  ORDER_CONFIRMED
  PRODUCTION
  INSTALLATION
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum QuotationStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
}

enum PaymentMode {
  UPI
  CASH
  BANK_TRANSFER
  CHEQUE
}

enum PaymentType {
  ADVANCE
  PARTIAL
  FINAL_BALANCE
  OTHER
}

enum ProductionStage {
  MATERIAL_ORDERED
  MATERIAL_RECEIVED
  CUTTING
  LAMINATION
  POLISHING
  HARDWARE
  QC
  READY
}

model User {
  id                   String                 @id @default(uuid()) @db.Uuid
  name                 String
  email                String                 @unique
  passwordHash         String
  role                 UserRole               @default(STAFF)
  isActive             Boolean                @default(true)
  assignedProjects     Project[]              @relation("ProjectAssignee")
  createdProjects      Project[]              @relation("ProjectCreator")
  projectStatusChanges ProjectStatusHistory[] @relation("ProjectStatusChangedBy")
  measurementSets      MeasurementSet[]       @relation("MeasurementMeasuredBy")
  recordedPayments     Payment[]              @relation("PaymentRecordedBy")
  projectDesigns       ProjectDesign[]        @relation("ProjectDesignUpdatedBy")
  productionJobs       ProductionJob[]        @relation("ProductionUpdatedBy")
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
}

model Customer {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  phone        String
  email        String?
  location     String?
  addressLine1 String?
  city         String?
  notes        String?
  leads        Lead[]
  projects     Project[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([phone])
}

model Lead {
  id          String     @id @default(uuid()) @db.Uuid
  fullName    String
  phone       String
  email       String?
  location    String?
  source      LeadSource @default(WEBSITE)
  interest    String?
  budgetMin   Decimal?   @db.Decimal(12, 2)
  budgetMax   Decimal?   @db.Decimal(12, 2)
  notes       String?
  status      LeadStatus @default(NEW)
  followUpAt  DateTime?
  contactedAt DateTime?
  convertedAt DateTime?
  customerId  String?    @db.Uuid
  customer    Customer?  @relation(fields: [customerId], references: [id])
  project     Project?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([phone])
  @@index([status])
}

model Project {
  id                     String                @id @default(uuid()) @db.Uuid
  code                   String                @unique
  title                  String
  scope                  String?
  furnitureType          String?
  location               String?
  addressLine1           String?
  city                   String?
  status                 ProjectStatus         @default(INQUIRY)
  priority               ProjectPriority       @default(MEDIUM)
  estimatedValue         Decimal?              @db.Decimal(12, 2)
  startDate              DateTime?
  expectedCompletionDate DateTime?
  notes                  String?
  customerId             String                @db.Uuid
  customer               Customer              @relation(fields: [customerId], references: [id])
  leadId                 String?               @unique @db.Uuid
  lead                   Lead?                 @relation(fields: [leadId], references: [id])
  assignedToId           String?               @db.Uuid
  assignedTo             User?                 @relation("ProjectAssignee", fields: [assignedToId], references: [id])
  createdById            String?               @db.Uuid
  createdBy              User?                 @relation("ProjectCreator", fields: [createdById], references: [id])
  statusHistory          ProjectStatusHistory[]
  measurements           MeasurementSet[]
  quotations             Quotation[]
  payments               Payment[]
  design                 ProjectDesign?
  productionJob          ProductionJob?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  @@index([status])
  @@index([customerId])
}

model ProjectStatusHistory {
  id          String        @id @default(uuid()) @db.Uuid
  projectId   String        @db.Uuid
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status      ProjectStatus
  note        String?
  changedById String?       @db.Uuid
  changedBy   User?         @relation("ProjectStatusChangedBy", fields: [changedById], references: [id])
  createdAt   DateTime      @default(now())

  @@index([projectId, createdAt])
}

model MeasurementSet {
  id           String            @id @default(uuid()) @db.Uuid
  projectId    String            @db.Uuid
  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version      Int               @default(1)
  isCurrent    Boolean           @default(true)
  siteNotes    String?
  measuredById String?           @db.Uuid
  measuredBy   User?             @relation("MeasurementMeasuredBy", fields: [measuredById], references: [id])
  rooms        MeasurementRoom[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([projectId, isCurrent])
}

model MeasurementRoom {
  id               String         @id @default(uuid()) @db.Uuid
  measurementSetId String         @db.Uuid
  measurementSet   MeasurementSet @relation(fields: [measurementSetId], references: [id], onDelete: Cascade)
  name             String
  width            Decimal?       @db.Decimal(10, 2)
  depth            Decimal?       @db.Decimal(10, 2)
  height           Decimal?       @db.Decimal(10, 2)
  wallNotes        String?
  openings         Json?
  obstacles        Json?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([measurementSetId])
}

model Quotation {
  id            String           @id @default(uuid()) @db.Uuid
  code          String           @unique
  projectId     String           @db.Uuid
  project       Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status        QuotationStatus  @default(DRAFT)
  subtotal      Decimal          @db.Decimal(12, 2)
  gstRate       Decimal          @db.Decimal(5, 2)
  gstAmount     Decimal          @db.Decimal(12, 2)
  grandTotal    Decimal          @db.Decimal(12, 2)
  notes         String?
  validUntil    DateTime?
  items         QuotationItem[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([projectId, createdAt])
  @@index([status])
}

model QuotationItem {
  id           String     @id @default(uuid()) @db.Uuid
  quotationId  String     @db.Uuid
  quotation    Quotation  @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  name         String
  category     String
  qty          Decimal    @db.Decimal(12, 2)
  unit         String
  rate         Decimal    @db.Decimal(12, 2)
  lineTotal    Decimal    @db.Decimal(12, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([quotationId])
}

model Payment {
  id           String      @id @default(uuid()) @db.Uuid
  customerName String
  projectId    String?     @db.Uuid
  project      Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  amount       Decimal     @db.Decimal(12, 2)
  mode         PaymentMode
  type         PaymentType
  paymentDate  DateTime
  reference    String?
  notes        String?
  recordedById String?     @db.Uuid
  recordedBy   User?       @relation("PaymentRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([projectId, paymentDate])
  @@index([paymentDate])
  @@index([type])
}

model ProjectDesign {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @unique @db.Uuid
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roomWidth    Decimal  @db.Decimal(10, 2)
  roomDepth    Decimal  @db.Decimal(10, 2)
  roomHeight   Decimal  @db.Decimal(10, 2)
  counterColor String
  items        Json
  isPublished  Boolean  @default(false)
  updatedById  String?  @db.Uuid
  updatedBy    User?    @relation("ProjectDesignUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  publishedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ProductionJob {
  id             String          @id @default(uuid()) @db.Uuid
  projectId      String          @unique @db.Uuid
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  currentStage   ProductionStage @default(MATERIAL_ORDERED)
  completedStages Json
  notes          String?
  updatedById    String?         @db.Uuid
  updatedBy      User?           @relation("ProductionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  startedAt      DateTime        @default(now())
  completedAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([currentStage])
}
